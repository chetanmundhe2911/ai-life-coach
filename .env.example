# ============================================================
# AI LIFE COACH — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=

# --- Model Settings ---
MODEL_NAME=gpt-4
EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=1000
TEMPERATURE=0.7

# --- RAG Settings ---
TOP_K_RESULTS=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- Paths ---
DOCS_DIR=./docs
RAG_CACHE_DIR=./.rag_cache

# --- Agent Settings ---
MAX_CONVERSATION_HISTORY=10
AGENT_NAME=Aria
